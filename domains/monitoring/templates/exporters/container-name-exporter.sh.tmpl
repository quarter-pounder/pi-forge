#!/usr/bin/env bash
set -uo pipefail

TEXTFILE_DIR="/textfile_collector"
TARGETS_FILE="${TEXTFILE_DIR}/container_log_targets.json"
TMP_TARGETS="${TARGETS_FILE}.tmp"
DOCKER_SOCK="/var/run/docker.sock"
FALLBACK_INTERVAL="${FALLBACK_INTERVAL:-300}"

mkdir -p "${TEXTFILE_DIR}"

write_empty_targets() {
  printf '[]\n' > "${TMP_TARGETS}"
}

export_container_log_targets() {
  write_empty_targets

  if [[ ! -S "${DOCKER_SOCK}" ]]; then
    return
  fi

  if ! command -v curl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
    return
  fi

  containers_json=$(curl -s --unix-socket "${DOCKER_SOCK}" "http://localhost/containers/json" 2>/dev/null)
  if [[ -z "${containers_json}" ]]; then
    return
  fi

  echo "${containers_json}" | jq -c '
    [.[] |
      .Id as $id |
      (.Names[0] // "" | ltrimstr("/")) as $name |
      select($name != "") |
      (.Labels["com.docker.compose.service"] // $name) as $service |
      (.Labels["com.docker.compose.project"] // "unknown") as $stack |
      {
        __path__: ("/var/lib/docker/containers/" + $id + "/" + $id + "-json.log"),
        container_id: $id[0:12],
        container: $name,
        container_name: $name,
        service: $service,
        service_name: $service,
        stack: $stack
      }
    ]
  ' > "${TMP_TARGETS}"
}

export_once() {
  export_container_log_targets
  mv "${TMP_TARGETS}" "${TARGETS_FILE}"
}

# ---------- EVENT STREAM ------------------------------------------------------
# discovery.docker in Alloy misses container replacement (grafana/alloy#3054),
# so we watch the Docker event stream directly and re-export on every
# start/die/destroy instead of polling on a timer.

watch_events() {
  curl -sN --unix-socket "${DOCKER_SOCK}" "http://localhost/events" 2>/dev/null \
    | jq -c 'select(.Type == "container" and (.Action == "start" or .Action == "die" or .Action == "destroy"))' 2>/dev/null
}

export_once

# Periodic safety net in case an event is ever missed or the stream silently stalls.
( while true; do sleep "${FALLBACK_INTERVAL}"; export_once; done ) &

while true; do
  if [[ ! -S "${DOCKER_SOCK}" ]]; then
    sleep 5
    continue
  fi

  while IFS= read -r _event; do
    # drain any additional events from the same burst (e.g. compose recreate)
    # into a single export instead of one per container.
    while IFS= read -r -t 0.3 _more; do :; done
    export_once
  done < <(watch_events)

  # curl exited: socket hiccup or docker daemon restart. Back off and reconnect.
  sleep 2
done
